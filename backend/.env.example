
# Application Config
FLASK_APP=run.py
FLASK_ENV=production
# Generate a strong key: `openssl rand -hex 32`
SECRET_KEY=change_this_to_a_secure_random_string
JWT_SECRET_KEY=change_this_to_another_secure_random_string

# Database
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://realty_user:secure_password@db:5432/realty_db

# Logging
LOG_TO_STDOUT=true
LOG_LEVEL=INFO

# Security
# Set to 'true' in production behind HTTPS
SSL_ENABLED=true
# Allowed origins for CORS (comma separated)
CORS_ORIGINS=https://app.realtyos.com,https://admin.realtyos.com

# File Storage
# For containerized deploys, map a volume to this path
UPLOAD_FOLDER=/app/app/static/uploads

# Rate Limiting
# Use Redis in production: redis://:password@redis_host:6379/0
RATELIMIT_STORAGE_URL=memory://
